# ==================================
# Application Settings
# ==================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_ENV=development
NEXT_TELEMETRY_DISABLED=1

# ==================================
# Authentication
# ==================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-random-string-here

# Admin Credentials (change in production!)
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=changeme

# ==================================
# Database Configuration
# ==================================
# SQLite (default)
DATABASE_URL=file:./data/ohbc_lite.db

# Uncomment for MySQL/PostgreSQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=user
# DB_PASSWORD=password
# DB_NAME=ohbc_lite

# ==================================
# Email Configuration
# ==================================
EMAIL_FROM=noreply@example.com
EMAIL_SERVER=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password

# ==================================
# YouTube API
# ==================================
NEXT_PUBLIC_YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_API_KEY=your-youtube-api-key
# Get your API key from: https://console.cloud.google.com/
# Enable YouTube Data API v3 for your project

# ==================================
# Bible APIs
# ==================================
# ESV API (server-side only)
ESV_API_KEY=your-esv-api-key
# Get your token from https://api.esv.org/account/profile/

# Bible API (for NIV and other versions)
BIBLE_API_KEY=your-bible-api-key
# Get your token from https://scripture.api.bible/

# ==================================
# Payment Processors
# ==================================
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_SECRET=your_paypal_secret_here

# Venmo (Optional)
NEXT_PUBLIC_VENMO_USERNAME=your_venmo_username
VENMO_NOTE=Donation to Our Church

# ==================================
# Payment Configuration (in cents)
# ==================================
MINIMUM_DONATION_AMOUNT=100  # $1.00
MAXIMUM_DONATION_AMOUNT=1000000  # $10,000.00

# ==================================
# Feature Flags
# ==================================
# Set to 'true' to enable maintenance mode
MAINTENANCE_MODE=false

# Set to 'true' to disable user registration
DISABLE_SIGNUP=false
