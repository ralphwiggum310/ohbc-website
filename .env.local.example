# ========================
# NextAuth.js Configuration
# ========================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secure_random_string_here

# ========================
# Database Configuration
# ========================
# SQLite configuration (development)
DATABASE_URL=sqlite:./data/ohbc-dev.db
# For production, you might want to use:
# DATABASE_URL=postgresql://user:password@localhost:5432/ohbc_prod

# ========================
# Payment Processors
# ========================
# Stripe (test mode - replace with live keys for production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# PayPal (sandbox mode - replace with live for production)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_sandbox

# ========================
# Bible API Configuration
# ========================
# ESV API (only one key needed)
ESV_API_KEY=your_esv_api_key

# General Bible API
BIBLE_API_KEY=your_bible_api_key

# ========================
# Social Media & OAuth
# ========================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# ========================
# Other Services
# ========================
# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key

# Venmo (optional)
NEXT_PUBLIC_VENMO_USERNAME=your_venmo_username
VENMO_NOTE=Donation to Our Church

# ========================
# Application Settings
# ========================
NODE_ENV=development
# NODE_ENV=production  # Uncomment for production

# ========================
# Security Notes:
# 1. Never commit .env.local to version control
# 2. Generate a strong NEXTAUTH_SECRET using:
#    openssl rand -base64 32
# 3. Rotate API keys regularly
# 4. Use environment-specific files for different environments
# ========================
