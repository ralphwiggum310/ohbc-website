{
  "name": "ohbc-lite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:api": "ts-node --project tsconfig.scripts.json scripts/test-bible-apis.ts",
    "db:init": "ts-node --project tsconfig.scripts.json scripts/init-db.ts",
    "db:generate-migration": "typeorm-ts-node-commonjs migration:generate ./src/migrations/$npm_config_name -d ./src/lib/db/data-source.ts",
    "db:run-migrations": "typeorm-ts-node-commonjs migration:run -d ./src/lib/db/data-source.ts",
    "db:revert-migration": "typeorm-ts-node-commonjs migration:revert -d ./src/lib/db/data-source.ts",
    "db:drop-schema": "typeorm-ts-node-commonjs schema:drop -d ./src/lib/db/data-source.ts",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "8.8.3",
    "@stripe/react-stripe-js": "3.7.0",
    "@stripe/stripe-js": "7.4.0",
    "@types/bcrypt": "6.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/nodemailer": "6.4.17",
    "@types/stripe": "8.0.416",
    "@types/uuid": "9.0.8",
    "axios": "1.10.0",
    "bcrypt": "6.0.0",
    "bcryptjs": "3.0.2",
    "better-sqlite3": "11.10.0",
    "bible-passage-reference-parser": "3.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "critters": "0.0.23",
    "framer-motion": "12.20.1",
    "jsonwebtoken": "9.0.2",
    "mysql2": "3.12.5",
    "next": "14.2.31",
    "next-auth": "4.24.11",
    "nodemailer": "6.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "6.0.0",
    "react-icons": "5.5.0",
    "sqlite3": "5.1.7",
    "typeorm": "0.3.25",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/next-auth": "3.13.0",
    "@types/node": "20.11.33",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.21",
    "css-loader": "7.1.2",
    "dotenv": "17.2.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.31",
    "next-transpile-modules": "10.0.1",
    "node-fetch": "3.3.2",
    "postcss": "8.5.6",
    "postcss-import": "16.1.1",
    "postcss-loader": "8.1.1",
    "postcss-nesting": "13.0.2",
    "reflect-metadata": "0.2.2",
    "style-loader": "4.0.0",
    "tailwindcss": "3.4.17",
    "ts-node": "10.9.2",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
