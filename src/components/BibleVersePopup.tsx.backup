};

const BibleVersePopup: React.FC<BibleVersePopupProps> = ({ reference, onClose }) => {
  const [verseText, setVerseText] = useState<string>('');

  // Get the verse text based on the reference
  const getVerseText = (ref: string): string => {
    return VERSE_TEXTS[ref] || `[Verse text not available for ${ref}]. This is a placeholder for the actual verse text.`;
  };

  useEffect(() => {
    setVerseText(getVerseText(reference));
  }, [reference]);

  // Close popup when clicking outside
  useEffect(() => {
    const handleClickOutside = (event: MouseEvent) => {
      const target = event.target as HTMLElement;
      if (target && !target.closest('.popup-content')) {
        onClose();
      }
    };

    // Add event listener
    document.addEventListener('mousedown', handleClickOutside);
    return () => {
      // Clean up
      document.removeEventListener('mousedown', handleClickOutside);
    };
  }, [onClose]);

  // Close on Escape key
  useEffect(() => {
    const handleEsc = (event: KeyboardEvent) => {
      if (event.key === 'Escape') {
        onClose();
      }
    };

    window.addEventListener('keydown', handleEsc);
    return () => window.removeEventListener('keydown', handleEsc);
  }, [onClose]);

  if (!reference) return null;

  return (
    <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
      <div className="bg-white rounded-lg shadow-xl max-w-2xl w-full max-h-[80vh] overflow-y-auto popup-content">
        <div className="p-6">
          <div className="flex justify-between items-start">
            <h3 className="text-xl font-bold text-gray-800 mb-4">{reference}</h3>
            <button
              onClick={onClose}
              className="text-gray-500 hover:text-gray-700 focus:outline-none text-2xl"
              aria-label="Close"
            >
              &times;
            </button>
          </div>
          
          <div className="prose max-w-none">
            <p className="text-gray-700 leading-relaxed">
              {verseText}
            </p>
            <div className="mt-4 text-sm text-gray-500 text-right">
              <p>English Standard Version (ESV)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default BibleVersePopup;
