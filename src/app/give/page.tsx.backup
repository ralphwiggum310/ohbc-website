// Backup created on 2025-12-04
// This is a backup of the working version of the Give page

'use client';

import { motion } from 'framer-motion';
import { useState, useEffect, useRef } from 'react';
import HeroSection from '@/components/HeroSection';

export default function GivePage() {
  const [isLoading, setIsLoading] = useState(true);
  const [hasError, setHasError] = useState(false);
  const iframeRef = useRef<HTMLIFrameElement>(null);
  
  // Direct URL to Zeffy's donation form
  const zeffyFormUrl = 'https://www.zeffy.com/en-US/donation-form/gifts-and-offerings';
  const zeffyEmbedUrl = 'https://www.zeffy.com/embed/donation-form/gifts-and-offerings';
  
  // Initialize with the full URL including timestamp
  const [iframeSrc, setIframeSrc] = useState(
    `${zeffyEmbedUrl}?embed=true&hideTitle=true&noHeader=true`
  );

  // Set the full URL with timestamp on client side
  useEffect(() => {
    const fullUrl = `${zeffyEmbedUrl}?embed=true&hideTitle=true&noHeader=true&t=${Date.now()}`;
    setIframeSrc(fullUrl);
  }, []);

  useEffect(() => {
    // Set a timeout to handle cases where the iframe fails to load
    const timer = setTimeout(() => {
      if (isLoading && !hasError) {
        console.log('Iframe load timeout reached, showing fallback');
        setHasError(true);
        setIsLoading(false);
      }
    }, 10000); // 10 second timeout

    return () => clearTimeout(timer);
  }, [isLoading, hasError]);

  const handleIframeLoad = () => {
    console.log('Iframe loaded successfully');
    setIsLoading(false);
  };

  const handleIframeError = (e: any) => {
    console.error('Iframe error:', e);
    // Try reloading once before showing error
    if (!hasError) {
      console.log('Attempting to reload iframe...');
      const retryUrl = `${zeffyEmbedUrl}?embed=true&hideTitle=true&noHeader=true&t=${Date.now()}`;
      setIframeSrc('');
      setTimeout(() => setIframeSrc(retryUrl), 50);
      setHasError(true); // Will show error on next failure
    } else {
      console.error('Iframe failed to load after retry');
      setIsLoading(false);
    }
  };

  const reloadIframe = () => {
    setHasError(false);
    setIsLoading(true);
    // Force a complete reload with new timestamp
    const newUrl = `${zeffyEmbedUrl}?embed=true&hideTitle=true&noHeader=true&t=${Date.now()}`;
    setIframeSrc(''); // Clear first to force reload
    setTimeout(() => setIframeSrc(newUrl), 50);
  };

  return (
    <div className="min-h-screen bg-gray-50">
      <HeroSection 
        title="Support Our Ministry"
        subtitle="Your generous gift helps advance gospel ministry in our area."
        className="bg-gradient-to-r from-gray-200 to-gray-300 text-gray-900"
      />
      
      <div className="px-3 sm:px-6 lg:px-8 py-8">
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5 }}
          className="max-w-5xl mx-auto w-full"
        >
          <div className="bg-white rounded-lg shadow-md p-4 sm:p-6 w-full mx-auto">
            <h2 className="text-xl sm:text-2xl font-bold mb-6 text-center text-gray-800">Make a Donation</h2>
            
            {!hasError ? (
              <div className="relative w-full rounded-lg border border-gray-200 bg-white overflow-hidden" style={{ minHeight: '800px' }}>
                {isLoading && (
                  <div className="absolute inset-0 flex items-center justify-center bg-gray-50 z-10">
                    <div className="animate-pulse flex flex-col items-center">
                      <div className="h-4 w-24 bg-gray-200 rounded mb-2"></div>
                      <div className="text-sm text-gray-500">Loading donation form...</div>
                    </div>
                  </div>
                )}
                <iframe
                  ref={iframeRef}
                  src={iframeSrc}
                  onLoad={handleIframeLoad}
                  onError={handleIframeError}
                  className="w-full h-full border-0"
                  title="Donation Form"
                  sandbox="allow-same-origin allow-scripts allow-popups allow-forms allow-storage-access-by-user-activation allow-top-navigation-by-user-activation allow-modals"
                  loading="eager"
                  allow="payment; fullscreen"
                  style={{
                    backgroundColor: 'transparent',
                    minHeight: '800px',
                    height: '100%',
                    width: '100%',
                    border: 'none',
                    position: 'relative',
                    overflow: 'auto',
                    visibility: isLoading ? 'hidden' : 'visible'
                  }}
                  referrerPolicy="strict-origin-when-cross-origin"
                  scrolling="yes"
                  frameBorder="0"
                  allowFullScreen
                />
              </div>
            ) : (
              <div className="text-center p-8 bg-red-50 rounded-lg border border-red-200">
                <h3 className="text-lg font-medium text-red-800 mb-4">Unable to load donation form</h3>
                <p className="text-red-600 mb-6">
                  We're having trouble loading the secure donation form. You can try again or visit Zeffy's website directly.
                </p>
                <div className="flex flex-wrap gap-4 justify-center">
                  <button
                    onClick={reloadIframe}
                    className="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors"
                  >
                    Try Again
                  </button>
                  <a
                    href={zeffyFormUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="px-6 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors"
                  >
                    Donate on Zeffy&apos;s Website
                  </a>
                </div>
                <div className="mt-6 pt-6 border-t border-gray-200">
                  <p className="text-sm text-gray-600">
                    If you continue to experience issues, please contact us at{' '}
                    <a href="mailto:info@orchardhillsbible.org" className="text-blue-600 hover:underline">
                      info@orchardhillsbible.org
                    </a>
                  </p>
                </div>
              </div>
            )}
          </div>
        </motion.div>
      </div>
    </div>
  );
}
